---
/**
 * CTA final de conversión: panel glass con borde de gradiente cónico
 * animado y doble vía de contacto (formulario + WhatsApp).
 */
import { CONTACT, whatsappUrl, withBase } from '../../lib/site';
---

<section class="section cta" id="cta-contacto" aria-labelledby="cta-title">
  <div class="container">
    <div class="cta__card" data-reveal>
      <div class="cta__glow" aria-hidden="true"></div>
      <p class="eyebrow">¿Listo para empezar?</p>
      <h2 id="cta-title">Comencemos algo <span class="text-gradient">grandioso</span> juntos</h2>
      <p class="lead cta__lead">
        Cuéntanos sobre el producto que quieres maquilar y te respondemos con una
        propuesta a la medida de tu marca.
      </p>
      <div class="cta__actions">
        <a class="btn btn--primary btn--lg" href={withBase('/contacto')}>
          Cotiza tu producto
          <svg class="btn__arrow" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
        </a>
        <a class="btn btn--ghost btn--lg cta__wa" href={whatsappUrl()} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12.04 2a9.9 9.9 0 0 0-8.57 14.86L2 22l5.27-1.38A9.92 9.92 0 1 0 12.04 2Zm0 18.06a8.1 8.1 0 0 1-4.13-1.13l-.3-.18-3.07.8.82-3-.2-.3a8.13 8.13 0 1 1 6.88 3.81Zm4.45-6.08c-.24-.12-1.44-.71-1.66-.79s-.39-.12-.55.12-.63.79-.77.95-.28.18-.53.06a6.65 6.65 0 0 1-1.95-1.2 7.3 7.3 0 0 1-1.35-1.68c-.14-.24 0-.37.1-.5s.25-.28.37-.43a1.66 1.66 0 0 0 .24-.4.45.45 0 0 0 0-.43c-.06-.12-.55-1.32-.75-1.81s-.4-.41-.55-.42h-.47a.9.9 0 0 0-.65.3 2.73 2.73 0 0 0-.85 2.03 4.74 4.74 0 0 0 1 2.52 10.88 10.88 0 0 0 4.16 3.68 14 14 0 0 0 1.39.51 3.35 3.35 0 0 0 1.53.1 2.5 2.5 0 0 0 1.64-1.16 2 2 0 0 0 .14-1.16c-.06-.1-.22-.16-.46-.28Z"/></svg>
          Escríbenos por WhatsApp
        </a>
      </div>
      <p class="cta__alt">
        O escríbenos directamente a
        <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
      </p>
    </div>
  </div>
</section>

<style>
  /* Borde de gradiente cónico ESTÁTICO: el anillo animado con @property
     repintaba toda la tarjeta en cada frame (auditoría perf); el estático
     se ve igual de premium y cuesta cero. */
  .cta__card {
    position: relative;
    text-align: center;
    padding: clamp(2.5rem, 2rem + 4vw, 5rem) clamp(1.5rem, 1rem + 3vw, 4rem);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(var(--c-surface-1), var(--c-surface-1)) padding-box,
      conic-gradient(
          from 210deg,
          rgba(var(--c-accent-rgb), 0.5),
          rgba(var(--c-cool-rgb), 0.15),
          rgba(var(--c-brand-rgb), 0.55),
          rgba(var(--c-accent-rgb), 0.5)
        )
        border-box;
    border: 1px solid transparent;
    overflow: hidden;
  }

  .cta__glow {
    position: absolute;
    inset: auto -20% -60% -20%;
    height: 110%;
    background: radial-gradient(
      50% 50% at 50% 100%,
      rgba(var(--c-brand-rgb), 0.22),
      transparent 70%
    );
    pointer-events: none;
  }

  .cta__card > .eyebrow {
    justify-content: center;
  }

  .cta__card > .eyebrow::before {
    display: none;
  }

  .cta__card h2 {
    position: relative;
    margin-top: var(--sp-4);
    font-size: var(--fs-3xl);
  }

  .cta__lead {
    position: relative;
    max-width: 44ch;
    margin: var(--sp-4) auto 0;
  }

  .cta__actions {
    position: relative;
    display: flex;
    justify-content: center;
    gap: var(--sp-4);
    flex-wrap: wrap;
    margin-top: var(--sp-6);
  }

  .cta__wa:hover {
    border-color: var(--c-whatsapp);
    color: var(--c-whatsapp);
    background: rgba(37, 211, 102, 0.08);
  }

  .cta__alt {
    position: relative;
    margin-top: var(--sp-5);
    font-size: var(--fs-sm);
    color: var(--c-text-faint);
  }

  .cta__alt a {
    color: var(--c-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
