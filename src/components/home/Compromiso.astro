---
/**
 * "Nuestro Compromiso" + los 3 pilares del sitio original
 * (copy completo extraído, con la gramática corregida).
 */
const pilares = [
  {
    title: 'Precios competitivos',
    text: 'Ofrecemos servicios de alta calidad a precios accesibles, asegurando que obtengas un gran valor por tu inversión.',
    icon: 'M7 7h.01M3.5 11.5 11 4a2 2 0 0 1 1.4-.6h5.2A2.4 2.4 0 0 1 20 5.8V11a2 2 0 0 1-.6 1.4l-7.5 7.5a2 2 0 0 1-2.8 0l-5.6-5.6a2 2 0 0 1 0-2.8Z',
  },
  {
    title: 'Estrategias a medida',
    text: 'No creemos en soluciones universales. Adaptamos nuestras estrategias y procesos para satisfacer las necesidades específicas de tu negocio, asegurando resultados óptimos y personalizados.',
    icon: 'M4 19c4-1 5-4 5.5-7M4 19c1-4 4-5 7-5.5M4 19 19 4m-4.5.5H19V9',
  },
  {
    title: 'Enfoque centrado en el cliente',
    text: 'Nos centramos en tus necesidades, desarrollando conceptos y productos que cautivarán a tu audiencia y superarán sus expectativas.',
    icon: 'M12 13a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Zm-7 8c.8-3.5 3.6-5 7-5s6.2 1.5 7 5',
  },
];
---

<section class="section compromiso" aria-labelledby="compromiso-title">
  <div class="container compromiso__grid">
    <div class="compromiso__intro" data-reveal>
      <p class="eyebrow">Nuestro compromiso</p>
      <h2 id="compromiso-title">Control de calidad en cada etapa de producción</h2>
      <p class="lead">
        En Pharma Sports Labs, nuestro compromiso es ofrecer suplementos deportivos y
        nutricionales de la más alta calidad, adaptados a las necesidades específicas
        de tu marca. Nos dedicamos a la innovación constante y a la excelencia
        en cada etapa de nuestro proceso de producción, asegurándonos de que cada
        producto que llevamos al mercado cumpla con los más altos estándares de
        eficacia y seguridad.
      </p>
      <p class="lead">
        Cada producto que sale de nuestro laboratorio es el resultado de rigurosos
        procesos de investigación y desarrollo.
      </p>
    </div>

    <ul class="compromiso__pilares" role="list">
      {pilares.map((p, i) => (
        <li class="pilar" data-reveal style={`--reveal-i: ${i}`}>
          <span class="pilar__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={p.icon}/></svg>
          </span>
          <div>
            <h3>{p.title}</h3>
            <p>{p.text}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .compromiso__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: clamp(2.5rem, 2rem + 3vw, 4.5rem);
    align-items: start;
  }

  @media (max-width: 860px) {
    .compromiso__grid {
      grid-template-columns: 1fr;
    }
  }

  .compromiso__intro h2 {
    margin-top: var(--sp-4);
  }

  .compromiso__intro .lead {
    margin-top: var(--sp-4);
    font-size: var(--fs-base);
  }

  .compromiso__pilares {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .pilar {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
    padding: var(--sp-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--c-border);
    background: var(--c-surface-2);
    transition: border-color var(--dur) var(--ease-out), transform var(--dur) var(--ease-out);
  }

  .pilar:hover {
    border-color: rgba(var(--c-accent-rgb), 0.4);
    transform: translateY(-3px);
  }

  .pilar__icon {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    color: var(--c-accent);
    background: var(--c-accent-soft);
    border: 1px solid rgba(var(--c-accent-rgb), 0.25);
  }

  .pilar h3 {
    font-size: var(--fs-md);
  }

  .pilar p {
    margin-top: var(--sp-2);
    color: var(--c-text-muted);
    font-size: var(--fs-sm);
  }
</style>
