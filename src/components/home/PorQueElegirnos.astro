---
/**
 * "Por qué elegirnos" con sus dos diferenciales del original y el
 * contador animado de clientes (el sitio real anima 600 → 800+).
 */
import { withBase } from '../../lib/site';

const features = [
  {
    title: 'Aseguramiento de calidad',
    text: 'La calidad no es solo una palabra de moda para nosotros: es parte integral de nuestro flujo de trabajo, lo que garantiza que todos nuestros productos cumplan con los más altos estándares.',
    icon: 'M12 2 4.5 5v6c0 5 3.2 8.8 7.5 11 4.3-2.2 7.5-6 7.5-11V5L12 2Zm-3 10 2.2 2.2L15.5 10',
  },
  {
    title: 'Soporte profesional',
    text: 'Nos comprometemos a garantizar un funcionamiento óptimo y a resolver cualquier eventualidad de manera eficiente, para asegurar la máxima satisfacción en cada etapa de producción.',
    icon: 'M12 17h.01M8.2 9a3.8 3.8 0 1 1 5.3 3.5c-1 .5-1.5 1-1.5 2M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
  },
];
---

<section class="section elegirnos" id="por-que-elegirnos" aria-labelledby="elegirnos-title">
  <div class="container elegirnos__grid">
    <div class="elegirnos__copy" data-reveal>
      <p class="eyebrow">Por qué elegirnos</p>
      <h2 id="elegirnos-title">Creando experiencias, logrando el éxito</h2>
      <p class="lead">
        Nuestro compromiso con la calidad y la excelencia es incomparable. Desde la
        definición del producto hasta la entrega final, nos aseguramos de que cada
        paso del proceso se ejecute a la perfección. No solo recibes un servicio:
        obtienes un socio comprometido con tu crecimiento y éxito.
      </p>

      <ul class="elegirnos__features" role="list">
        {features.map((f) => (
          <li>
            <span class="elegirnos__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={f.icon}/></svg>
            </span>
            <div>
              <h3>{f.title}</h3>
              <p>{f.text}</p>
            </div>
          </li>
        ))}
      </ul>

      <a class="btn btn--ghost elegirnos__btn" href={withBase('/sobre-nosotros')}>
        Conoce más sobre nosotros
        <svg class="btn__arrow" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
      </a>
    </div>

    <div class="elegirnos__visual" data-reveal style="--reveal-i: 1">
      <figure class="elegirnos__media">
        <img
          src={withBase('/images/deporte-rendimiento.webp')}
          alt="Deportista entrenando al aire libre — el rendimiento que impulsan nuestros suplementos"
          width="1200"
          height="800"
          loading="lazy"
          decoding="async"
        />
      </figure>
      <div class="elegirnos__counter">
        <p class="elegirnos__number">
          <span data-count-to="800">800</span><span class="elegirnos__plus">+</span>
        </p>
        <p class="elegirnos__label">Clientes satisfechos</p>
      </div>
    </div>
  </div>
</section>

<style>
  .elegirnos__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(2.5rem, 2rem + 3vw, 4.5rem);
    align-items: center;
  }

  @media (max-width: 900px) {
    .elegirnos__grid {
      grid-template-columns: 1fr;
    }
  }

  .elegirnos__copy h2 {
    margin-top: var(--sp-4);
  }

  .elegirnos__copy .lead {
    margin-top: var(--sp-4);
  }

  .elegirnos__features {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    margin-top: var(--sp-6);
  }

  .elegirnos__features li {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
  }

  .elegirnos__icon {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    color: var(--c-accent);
    background: var(--c-accent-soft);
    border: 1px solid rgba(var(--c-accent-rgb), 0.25);
  }

  .elegirnos__features h3 {
    font-size: var(--fs-md);
  }

  .elegirnos__features p {
    margin-top: var(--sp-2);
    color: var(--c-text-muted);
    font-size: var(--fs-sm);
  }

  .elegirnos__btn {
    margin-top: var(--sp-6);
  }

  /* --- visual + counter ---------------------------------------- */
  .elegirnos__visual {
    position: relative;
  }

  .elegirnos__media img {
    border-radius: var(--radius-xl);
    border: 1px solid var(--c-border-strong);
    box-shadow: var(--shadow-lg), 0 0 80px rgba(var(--c-brand-rgb), 0.16);
  }

  .elegirnos__counter {
    position: absolute;
    left: clamp(-1.5rem, -2vw, -0.5rem);
    bottom: clamp(-1.25rem, -1.5vw, -0.5rem);
    padding: var(--sp-5) var(--sp-6);
    border-radius: var(--radius-lg);
    background: rgba(var(--c-base-rgb), 0.82);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(var(--c-accent-rgb), 0.3);
    box-shadow: var(--shadow-md);
  }

  .elegirnos__number {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-2xl);
    line-height: 1;
    background: var(--grad-accent);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* caja de ancho fijo: los dígitos cambian sin mover el '+' (cero CLS) */
  .elegirnos__number span[data-count-to] {
    display: inline-block;
    min-width: 3ch;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .elegirnos__label {
    margin-top: var(--sp-2);
    color: var(--c-text-muted);
    font-size: var(--fs-sm);
  }
</style>
