---
/**
 * GRACIAS — destino del redirect de Web3Forms tras un envío exitoso.
 * noindex: no aporta nada a buscadores.
 */
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { whatsappUrl, withBase } from '../lib/site';
---

<Layout
  title="¡Solicitud enviada!"
  description="Hemos recibido tu solicitud. Te responderemos muy pronto."
  path="/gracias"
>
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <Header />

  <main id="main">
    <section class="section gracias">
      <div class="container gracias__card">
        <span class="gracias__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="34" height="34" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 13 4 4L19 7"/></svg>
        </span>
        <h1>¡Solicitud <span class="text-gradient">enviada</span>!</h1>
        <p class="lead">
          Hemos recibido tu solicitud. Nuestro equipo la revisará y te responderá
          muy pronto al correo o teléfono que nos compartiste.
        </p>
        <div class="gracias__actions">
          <a class="btn btn--primary" href={withBase('/')}>
            Volver al inicio
            <svg class="btn__arrow" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
          </a>
          <a class="btn btn--ghost" href={whatsappUrl()} target="_blank" rel="noopener">
            ¿Urgente? Escríbenos por WhatsApp<span class="sr-only"> — se abre en una pestaña nueva</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>

<style>
  .gracias {
    padding-block: clamp(4rem, 3rem + 5vw, 7rem);
  }

  .gracias__card {
    text-align: center;
    max-width: 42rem;
  }

  .gracias__icon {
    display: inline-grid;
    place-items: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    color: var(--c-success);
    background: rgba(84, 224, 138, 0.1);
    border: 1px solid rgba(84, 224, 138, 0.35);
    margin-bottom: var(--sp-5);
  }

  .gracias__card h1 {
    font-size: var(--fs-2xl);
  }

  .gracias__card .lead {
    margin-top: var(--sp-4);
  }

  .gracias__actions {
    display: flex;
    justify-content: center;
    gap: var(--sp-4);
    flex-wrap: wrap;
    margin-top: var(--sp-6);
  }
</style>
