---
/**
 * SERVICIOS — contenido completo del original reconstruido:
 * maquila destacada, 5 bloques de servicio, lista de capacidades,
 * beneficios y CTA de cotización.
 */
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import PageHero from '../components/PageHero.astro';
import CTAContacto from '../components/home/CTAContacto.astro';
import { withBase } from '../lib/site';

const bloques = [
  {
    title: 'Formulación y desarrollo de productos',
    text: 'Creación de fórmulas personalizadas según las especificaciones del cliente. Investigación y desarrollo de nuevos productos nutricionales.',
    icon: 'M9 3h6m-5 0v5.2L4.6 17a3 3 0 0 0 2.6 4.5h9.6a3 3 0 0 0 2.6-4.5L14 8.2V3M7.5 14h9',
  },
  {
    title: 'Opciones de personalización',
    text: 'Adaptación del sabor, color y textura de los productos según las preferencias del cliente.',
    icon: 'M12 3v3m0 12v3M3 12h3m12 0h3M5.6 5.6l2.1 2.1m8.6 8.6 2.1 2.1m0-12.8-2.1 2.1M7.7 16.3l-2.1 2.1M12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z',
  },
  {
    title: 'Envasado y etiquetado',
    text: 'Servicios completos de envasado y etiquetado, incluyendo opciones de empaques diversos para satisfacer las necesidades del cliente.',
    icon: 'M21 16V8a2 2 0 0 0-1-1.7l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.7l7 4a2 2 0 0 0 2 0l7-4a2 2 0 0 0 1-1.7ZM3.3 7l8.7 5 8.7-5M12 22V12',
  },
  {
    title: 'Control de alérgenos y seguridad alimentaria',
    text: 'Protocolos estrictos para garantizar la seguridad y la ausencia de contaminantes en los productos.',
    icon: 'M12 2 4.5 5v6c0 5 3.2 8.8 7.5 11 4.3-2.2 7.5-6 7.5-11V5L12 2Zm-3 10 2.2 2.2L15.5 10',
  },
  {
    title: 'Cumplimiento con normativas',
    text: 'Acompañamos el cumplimiento de las regulaciones y normativas aplicables en Colombia, y te asesoramos según los requisitos del mercado de destino.',
    icon: 'M9 12h6m-6 4h4M8 3h8a2 2 0 0 1 2 2v15a1 1 0 0 1-1.5.9L15 20l-1.5.9a1 1 0 0 1-1 0L11 20l-1.5.9A1 1 0 0 1 8 20V5a2 2 0 0 1 0-2Z',
  },
];

const maquilaCaps = [
  {
    title: 'Producción a gran escala',
    text: 'Capacidad para producir grandes volúmenes de suplementos deportivos, vitaminas, minerales y otros productos nutricionales.',
  },
  {
    title: 'Flexibilidad en el volumen de producción',
    text: 'Ofrecemos servicios tanto para pequeños lotes piloto como para grandes producciones comerciales.',
  },
  {
    title: 'Tecnología de producción avanzada',
    text: 'Utilización de equipos de última generación para garantizar la máxima eficiencia y calidad en el proceso de producción.',
  },
];

const checklist = [
  'Formulación y desarrollo de productos',
  'Producción y maquila',
  'Envasado y etiquetado',
  'Control de calidad',
  'Asesoría regulatoria',
];

const beneficios = [
  'Un producto único que te diferencia de la competencia.',
  'Una mejor experiencia para tus clientes, que se traduce en mayor satisfacción.',
  'Integración total con tu operación de producción para un mayor rendimiento.',
];
---

<Layout
  title="Servicios"
  description="Servicios de maquila de suplementos deportivos: formulación, producción a gran escala, envasado y etiquetado, control de calidad y asesoría regulatoria en Bogotá."
  path="/servicios"
>
  <Header />

  <main id="main">
    <PageHero eyebrow="Servicios" title="Maquila de suplementos deportivos" accent="suplementos">
      <p>
        Desarrollamos soluciones de producción que destacan en calidad y precisión, y
        que potencian los resultados comerciales de tu marca: de la fórmula al
        producto terminado.
      </p>
    </PageHero>

    <!-- Maquila destacada + visual de productos -->
    <section class="section maquila" aria-labelledby="maquila-title">
      <div class="container maquila__grid">
        <div data-reveal>
          <h2 id="maquila-title">Producción y maquila</h2>
          <ul class="maquila__caps" role="list">
            {maquilaCaps.map((c) => (
              <li>
                <h3>{c.title}</h3>
                <p>{c.text}</p>
              </li>
            ))}
          </ul>
        </div>

        <div class="maquila__visual" data-reveal style="--reveal-i: 1" aria-hidden="true">
          <div class="maquila__glow"></div>
          <svg class="maquila__productos" viewBox="0 0 420 360" fill="none">
            <defs>
              <linearGradient id="sv-blanco" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0" stop-color="#e8ecf2"/>
                <stop offset="0.5" stop-color="#ffffff"/>
                <stop offset="1" stop-color="#c9d1dc"/>
              </linearGradient>
              <linearGradient id="sv-negro" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0" stop-color="#1b2030"/>
                <stop offset="0.5" stop-color="#272e42"/>
                <stop offset="1" stop-color="#0b0d15"/>
              </linearGradient>
              <linearGradient id="sv-band" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0" stop-color="#046bd2"/>
                <stop offset="1" stop-color="#38bdf8"/>
              </linearGradient>
            </defs>

            <!-- bolsa de proteína (atrás) -->
            <path d="M150 96h120c4 0 7 3 8 7l14 180c1 9-6 17-15 17H143c-9 0-16-8-15-17l14-180c1-4 4-7 8-7Z" fill="url(#sv-negro)"/>
            <path d="M150 96h120l3 18H147l3-18Z" fill="#0b0d15"/>
            <rect x="150" y="160" width="120" height="64" fill="#0d1018"/>
            <rect x="150" y="160" width="120" height="2.5" fill="url(#sv-band)"/>
            <rect x="150" y="221.5" width="120" height="2.5" fill="url(#sv-band)"/>
            <text x="210" y="186" text-anchor="middle" font-family="Space Grotesk Variable, sans-serif" font-size="11" letter-spacing="3" fill="#9ba1ad">PHARMA SPORTS</text>
            <text x="210" y="208" text-anchor="middle" font-family="Space Grotesk Variable, sans-serif" font-weight="700" font-size="17" fill="#f4f6f8">PROTEÍNA</text>

            <!-- tarro blanco -->
            <rect x="36" y="148" width="120" height="32" rx="9" fill="#d4dae3"/>
            <path d="M30 178c0-6 5-11 11-11h110c6 0 11 5 11 11v140c0 12-10 22-22 22H52c-12 0-22-10-22-22V178Z" fill="url(#sv-blanco)"/>
            <rect x="30" y="210" width="132" height="84" fill="#f6f8fb"/>
            <rect x="30" y="210" width="132" height="2.5" fill="url(#sv-band)"/>
            <rect x="30" y="291.5" width="132" height="2.5" fill="url(#sv-band)"/>
            <text x="96" y="240" text-anchor="middle" font-family="Space Grotesk Variable, sans-serif" font-size="10" letter-spacing="2.5" fill="#6b7280">CÁPSULAS</text>
            <text x="96" y="262" text-anchor="middle" font-family="Space Grotesk Variable, sans-serif" font-weight="700" font-size="14" fill="#11131a">VITAMINAS</text>

            <!-- tarro negro (frente) -->
            <rect x="262" y="128" width="128" height="34" rx="10" fill="url(#sv-band)"/>
            <path d="M256 160c0-6 5-11 11-11h118c6 0 11 5 11 11v152c0 13-10 23-23 23h-94c-13 0-23-10-23-23V160Z" fill="url(#sv-negro)"/>
            <rect x="256" y="196" width="140" height="90" fill="#0d1018"/>
            <rect x="256" y="196" width="140" height="2.5" fill="url(#sv-band)"/>
            <rect x="256" y="283.5" width="140" height="2.5" fill="url(#sv-band)"/>
            <text x="326" y="226" text-anchor="middle" font-family="Space Grotesk Variable, sans-serif" font-size="10" letter-spacing="2.5" fill="#9ba1ad">PRE-WORKOUT</text>
            <text x="326" y="250" text-anchor="middle" font-family="Space Grotesk Variable, sans-serif" font-weight="700" font-size="16" fill="#3b9dff">ENERGY+</text>

            <!-- base -->
            <ellipse cx="210" cy="338" rx="190" ry="12" fill="#046bd2" opacity="0.12"/>
          </svg>
        </div>
      </div>
    </section>

    <!-- 5 bloques de servicio -->
    <section class="section detalles" aria-labelledby="detalles-title">
      <div class="container">
        <div class="section-head" data-reveal>
          <p class="eyebrow">Qué hacemos</p>
          <h2 id="detalles-title">Servicios integrales, de la fórmula a la entrega</h2>
        </div>
        <ul class="detalles__grid" role="list">
          {bloques.map((b, i) => (
            <li class="detalle" data-reveal style={`--reveal-i: ${i % 3}`}>
              <span class="detalle__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d={b.icon}/></svg>
              </span>
              <h3>{b.title}</h3>
              <p>{b.text}</p>
            </li>
          ))}
          <li class="detalle detalle--cta" data-reveal style="--reveal-i: 2">
            <h3>¿Tu proyecto necesita algo más?</h3>
            <p>Cuéntanos qué quieres fabricar y armamos la solución a tu medida.</p>
            <a class="btn btn--primary" href={withBase('/contacto')}>
              Obtén una cotización
              <svg class="btn__arrow" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
            </a>
          </li>
        </ul>
      </div>
    </section>

    <!-- checklist + beneficios -->
    <section class="section beneficios" aria-labelledby="beneficios-title">
      <div class="container beneficios__grid">
        <div class="beneficios__lista" data-reveal>
          <p class="eyebrow">Nuestros servicios</p>
          <h2>Capacidades del laboratorio</h2>
          <ul role="list">
            {checklist.map((c) => (
              <li>
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>
                {c}
              </li>
            ))}
          </ul>
        </div>

        <div class="beneficios__copy" data-reveal style="--reveal-i: 1">
          <h2 id="beneficios-title">Beneficios del servicio</h2>
          <p>
            Nuestro equipo de expertos utiliza las tecnologías más avanzadas y las
            mejores prácticas de la industria de la suplementación para asegurar que
            cada producto que fabricamos no sea solo un complemento nutricional, sino
            una herramienta poderosa para el bienestar y el éxito de tu negocio.
          </p>
          <ul role="list">
            {beneficios.map((b) => (
              <li>
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 2 4.5 5v6c0 5 3.2 8.8 7.5 11 4.3-2.2 7.5-6 7.5-11V5L12 2Z"/></svg>
                {b}
              </li>
            ))}
          </ul>
          <p>
            Pero nuestro trabajo no termina con la entrega de tu producto. Brindamos
            soporte y asesoría continuos para que tu línea de suplementos se
            mantenga actualizada, segura y funcionando al máximo: nuevas
            formulaciones, actualización de ingredientes o cualquier eventualidad.
          </p>
        </div>
      </div>
    </section>

    <CTAContacto />
  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>

<style>
  /* --- maquila ------------------------------------------------ */
  .maquila__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: clamp(2.5rem, 2rem + 3vw, 4.5rem);
    align-items: center;
  }

  @media (max-width: 900px) {
    .maquila__grid {
      grid-template-columns: 1fr;
    }
  }

  .maquila__grid > * {
    min-width: 0;
  }

  .maquila__caps {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    margin-top: var(--sp-6);
  }

  .maquila__caps li {
    padding: var(--sp-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--c-border);
    background: var(--c-surface-2);
    border-left: 3px solid var(--c-brand);
    transition: border-color var(--dur) var(--ease-out), transform var(--dur) var(--ease-out);
  }

  .maquila__caps li:hover {
    border-color: rgba(var(--c-accent-rgb), 0.4);
    border-left-color: var(--c-accent);
    transform: translateX(4px);
  }

  .maquila__caps h3 {
    font-size: var(--fs-md);
  }

  .maquila__caps p {
    margin-top: var(--sp-2);
    color: var(--c-text-muted);
    font-size: var(--fs-sm);
  }

  .maquila__visual {
    position: relative;
    display: grid;
    place-items: center;
  }

  .maquila__glow {
    position: absolute;
    inset: 8%;
    border-radius: 50%;
    background: radial-gradient(
      closest-side,
      rgba(var(--c-brand-rgb), 0.25),
      rgba(var(--c-brand-rgb), 0) 75%
    );
  }

  .maquila__productos {
    position: relative;
    width: 100%;
    max-width: 26rem;
    filter: drop-shadow(0 24px 40px rgba(0, 0, 0, 0.55));
    animation: maquila-float 8s ease-in-out infinite;
  }

  @keyframes maquila-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .maquila__productos {
      animation: none;
    }
  }

  /* --- detalles ----------------------------------------------- */
  .detalles .section-head {
    margin-bottom: var(--sp-7);
  }

  .detalles__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }

  @media (max-width: 980px) {
    .detalles__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 620px) {
    .detalles__grid {
      grid-template-columns: 1fr;
    }
  }

  .detalle {
    padding: var(--sp-6);
    border-radius: var(--radius-lg);
    border: 1px solid var(--c-border);
    background: var(--c-surface-2);
    transition: border-color var(--dur) var(--ease-out), transform var(--dur) var(--ease-out),
      background-color var(--dur) var(--ease-out);
  }

  .detalle:hover {
    border-color: rgba(var(--c-accent-rgb), 0.45);
    background: var(--c-surface-3);
    transform: translateY(-4px);
  }

  .detalle__icon {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    color: var(--c-accent);
    background: var(--c-accent-soft);
    border: 1px solid rgba(var(--c-accent-rgb), 0.25);
    margin-bottom: var(--sp-5);
  }

  .detalle h3 {
    font-size: var(--fs-md);
  }

  .detalle p {
    margin-top: var(--sp-3);
    color: var(--c-text-muted);
    font-size: var(--fs-sm);
  }

  .detalle--cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--sp-2);
    background:
      linear-gradient(140deg, rgba(var(--c-brand-rgb), 0.22), rgba(var(--c-brand-rgb), 0.04) 60%),
      var(--c-surface-2);
    border-color: rgba(var(--c-accent-rgb), 0.3);
  }

  .detalle--cta .btn {
    margin-top: var(--sp-4);
  }

  /* --- beneficios ---------------------------------------------- */
  .beneficios {
    background: var(--c-surface-1);
    border-block: 1px solid var(--c-border);
  }

  .beneficios__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2.5rem, 2rem + 3vw, 4.5rem);
    align-items: start;
  }

  @media (max-width: 860px) {
    .beneficios__grid {
      grid-template-columns: 1fr;
    }
  }

  .beneficios__lista h2 {
    margin-top: var(--sp-4);
  }

  .beneficios__lista ul {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
  }

  .beneficios__lista li {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-5);
    border-radius: var(--radius-pill);
    border: 1px solid var(--c-border);
    background: var(--c-surface-2);
    font-family: var(--font-display);
    font-weight: var(--fw-medium);
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    transition: border-color var(--dur) var(--ease-out), transform var(--dur) var(--ease-out);
  }

  .beneficios__lista li:hover {
    border-color: rgba(var(--c-accent-rgb), 0.4);
    transform: translateX(4px);
  }

  .beneficios__lista svg {
    color: var(--c-accent);
    flex-shrink: 0;
  }

  .beneficios__copy p {
    color: var(--c-text-muted);
    margin-top: var(--sp-4);
  }

  .beneficios__copy ul {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-block: var(--sp-5);
  }

  .beneficios__copy li {
    display: flex;
    gap: var(--sp-3);
    align-items: flex-start;
    color: var(--c-text);
  }

  .beneficios__copy li svg {
    color: var(--c-accent);
    flex-shrink: 0;
    margin-top: 3px;
  }
</style>
