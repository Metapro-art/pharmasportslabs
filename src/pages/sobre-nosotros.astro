---
/**
 * SOBRE NOSOTROS — reconstruida con el copy original rescatado del
 * snapshot de Wayback (la página ya no existe en el sitio vivo):
 * intro, misión / visión / meta e "Historias de clientes".
 */
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import PageHero from '../components/PageHero.astro';
import Testimonios from '../components/home/Testimonios.astro';
import CTAContacto from '../components/home/CTAContacto.astro';
import { withBase } from '../lib/site';

const principios = [
  {
    title: 'Nuestra misión',
    text: 'Potenciar a las empresas mediante la maquila de suplementos innovadores y de alta calidad, mejorando su oferta de productos y contribuyendo a un crecimiento significativo en el mercado.',
    icon: 'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm0-4.5a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9ZM12 13a1 1 0 1 0 0-2',
  },
  {
    title: 'Nuestra visión',
    text: 'Ser el líder en la maquila de suplementos, reconocido a nivel mundial por nuestras soluciones innovadoras, nuestro compromiso con la calidad y nuestro enfoque en el éxito de nuestros clientes.',
    icon: 'M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Zm9.5 3a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z',
  },
  {
    title: 'Nuestra meta',
    text: 'Superar las expectativas de nuestros clientes ofreciendo soluciones superiores adaptadas a sus necesidades únicas, construyendo confianza y logrando éxitos compartidos.',
    icon: 'M8 21h8m-4-4v4m-7-9a7 7 0 1 0 14 0V4H5v8ZM5 6H3a1 1 0 0 0-1 1c0 2 1.5 3.5 3.5 3.5M19 6h2a1 1 0 0 1 1 1c0 2-1.5 3.5-3.5 3.5',
  },
];
---

<Layout
  title="Sobre nosotros"
  description="Somos un equipo apasionado de expertos en suplementación en Bogotá. Conoce la misión, visión y meta de Pharma Sports Labs, tu socio de maquila de suplementos deportivos."
  path="/sobre-nosotros"
>
  <Header />

  <main id="main">
    <PageHero
      eyebrow="Sobre nosotros"
      title="Innovación y calidad de principio a fin"
      accent="Innovación y calidad"
    >
      <p>
        Somos un equipo apasionado de expertos en suplementación, dedicados a ofrecer
        productos de la más alta calidad. Creemos en el poder de la ciencia y la
        innovación para transformar la nutrición, elevando la salud y el rendimiento
        de los consumidores.
      </p>
    </PageHero>

    <!-- intro + foto -->
    <section class="section equipo" aria-labelledby="equipo-title">
      <div class="container equipo__grid">
        <div class="equipo__copy" data-reveal>
          <p class="eyebrow">Quiénes somos</p>
          <h2 id="equipo-title">No somos solo una empresa de maquila: somos tu socio estratégico</h2>
          <p class="lead">
            Te acompañamos en el viaje hacia la excelencia nutricional. Desde nuestros
            inicios nos ha movido una misión: impulsar a las empresas para que
            alcancen su máximo potencial. Hemos trabajado con cientos de clientes de
            la industria, brindando soluciones personalizadas que aceleran el
            crecimiento y generan valor.
          </p>
          <ul class="equipo__claves" role="list">
            <li>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>
              Estrategias adaptadas a las necesidades de tu negocio
            </li>
            <li>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>
              Asistencia continua en cada etapa
            </li>
            <li>
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>
              Equipo especializado en producción y calidad
            </li>
          </ul>
        </div>

        <!-- Probable LCP en desktop: eager + sin reveal de opacidad -->
        <figure class="equipo__media">
          <img
            src={withBase('/images/laboratorio-tubos.webp')}
            alt="Tubos de ensayo en el laboratorio de control de calidad"
            width="1200"
            height="801"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </figure>
      </div>
    </section>

    <!-- misión / visión / meta -->
    <section class="section principios" aria-labelledby="principios-title">
      <div class="container">
        <div class="section-head" data-reveal>
          <p class="eyebrow">Lo que nos mueve</p>
          <h2 id="principios-title">Misión, visión y meta</h2>
        </div>
        <ul class="principios__grid" role="list">
          {principios.map((p, i) => (
            <li class="principio" data-reveal style={`--reveal-i: ${i}`}>
              <span class="principio__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d={p.icon}/></svg>
              </span>
              <h3>{p.title}</h3>
              <p>{p.text}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- visión materializada -->
    <section class="section vision" aria-labelledby="vision-title">
      <div class="container vision__card" data-reveal>
        <p class="eyebrow">Historias de clientes</p>
        <h2 id="vision-title">Tu visión, <span class="text-gradient">materializada</span></h2>
        <p class="lead">
          Celebramos las transformaciones que hemos catalizado para nuestros clientes:
          historias de innovación, resiliencia y éxito que muestran el impacto real de
          nuestras soluciones en distintos negocios, impulsando su crecimiento.
        </p>
      </div>
    </section>

    <Testimonios />
    <CTAContacto />
  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>

<style>
  .equipo__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: clamp(2.5rem, 2rem + 3vw, 4.5rem);
    align-items: center;
  }

  @media (max-width: 860px) {
    .equipo__grid {
      grid-template-columns: 1fr;
    }
  }

  .equipo__grid > * {
    min-width: 0;
  }

  .equipo__copy h2 {
    margin-top: var(--sp-4);
  }

  .equipo__copy .lead {
    margin-top: var(--sp-4);
    font-size: var(--fs-base);
  }

  .equipo__claves {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-top: var(--sp-5);
  }

  .equipo__claves li {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    color: var(--c-text-muted);
    font-size: var(--fs-sm);
  }

  .equipo__claves svg {
    color: var(--c-accent);
    flex-shrink: 0;
  }

  .equipo__media img {
    border-radius: var(--radius-xl);
    border: 1px solid var(--c-border-strong);
    box-shadow: var(--shadow-lg), 0 0 80px rgba(var(--c-brand-rgb), 0.18);
  }

  /* --- principios ---------------------------------------------- */
  .principios {
    background: var(--c-surface-1);
    border-block: 1px solid var(--c-border);
  }

  .principios .section-head {
    margin-bottom: var(--sp-7);
  }

  .principios__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }

  @media (max-width: 900px) {
    .principios__grid {
      grid-template-columns: 1fr;
      max-width: 36rem;
    }
  }

  .principio {
    padding: var(--sp-6);
    border-radius: var(--radius-lg);
    border: 1px solid var(--c-border);
    background: var(--c-surface-2);
    transition: border-color var(--dur) var(--ease-out), transform var(--dur) var(--ease-out);
  }

  .principio:hover {
    border-color: rgba(var(--c-accent-rgb), 0.45);
    transform: translateY(-4px);
  }

  .principio__icon {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    color: var(--c-accent);
    background: var(--c-accent-soft);
    border: 1px solid rgba(var(--c-accent-rgb), 0.25);
    margin-bottom: var(--sp-5);
  }

  .principio h3 {
    font-size: var(--fs-md);
  }

  .principio p {
    margin-top: var(--sp-3);
    color: var(--c-text-muted);
    font-size: var(--fs-sm);
  }

  /* --- visión --------------------------------------------------- */
  .vision__card {
    text-align: center;
    padding-block: var(--sp-6);
  }

  .vision__card .eyebrow {
    justify-content: center;
  }

  .vision__card .eyebrow::before {
    display: none;
  }

  .vision__card h2 {
    margin-top: var(--sp-4);
  }

  .vision__card .lead {
    max-width: 56ch;
    margin: var(--sp-4) auto 0;
  }
</style>
